{
  "name": "orchestra",
  "version": "0.1.0",
  "private": true,
  "description": "Desktop dev orchestrator for local stacks",
  "main": "dist-electron/electron/main.js",
  "type": "module",
  "scripts": {
    "dev": "concurrently -k \"npm:dev:renderer\" \"npm:dev:electron\"",
    "dev:renderer": "vite --port 3322 --strictPort",
    "dev:electron": "wait-on tcp:3322 && tsc -p tsconfig.electron.json && electron .",
    "build": "npm run build:renderer && npm run build:electron",
    "build:renderer": "vite build",
    "build:electron": "tsc -p tsconfig.electron.json",
    "devctl": "tsx scripts/devctl.ts",
    "auto-setup": "tsx scripts/auto-setup-services.ts",
    "verify": "tsx scripts/verify.ts",
    "ports": "tsx scripts/ports-manager.ts",
    "ports:list": "tsx scripts/ports-manager.ts list",
    "ports:profiles": "tsx scripts/ports-manager.ts profiles",
    "ports:full": "tsx scripts/ports-manager.ts profile full",
    "ports:clawd": "tsx scripts/ports-manager.ts profile clawd-only",
    "ports:orchestra": "tsx scripts/ports-manager.ts profile orchestra-only",
    "ports:minimal": "tsx scripts/ports-manager.ts profile minimal",
    "tokens": "tsx scripts/tokens-manager.ts",
    "tokens:list": "tsx scripts/tokens-manager.ts list",
    "tokens:status": "tsx scripts/tokens-manager.ts status",
    "tokens:envs": "tsx scripts/tokens-manager.ts environments",
    "tokens:dev": "tsx scripts/tokens-manager.ts env development",
    "tokens:staging": "tsx scripts/tokens-manager.ts env staging",
    "tokens:prod": "tsx scripts/tokens-manager.ts env production",
    "dist": "npm run build && electron-builder",
    "dist:mac": "npm run build && electron-builder --mac",
    "dist:win": "npm run build && electron-builder --win",
    "dist:linux": "npm run build && electron-builder --linux",
    "dist:all": "npm run build && electron-builder -mwl",
    "typecheck": "tsc --noEmit && tsc -p tsconfig.electron.json --noEmit",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "build": {
    "appId": "dev.orchestra.app",
    "productName": "Orchestra",
    "files": [
      "dist/**",
      "dist-electron/**",
      "package.json",
      "config/**"
    ],
    "mac": {
      "category": "public.app-category.developer-tools",
      "target": [
        "dmg",
        "zip"
      ],
      "icon": "build/icon.icns",
      "hardenedRuntime": true,
      "gatekeeperAssess": false
    },
    "win": {
      "target": [
        "nsis",
        "portable"
      ],
      "icon": "build/icon.ico"
    },
    "linux": {
      "target": [
        "AppImage",
        "deb"
      ],
      "icon": "build/icon.png",
      "category": "Development"
    },
    "nsis": {
      "oneClick": false,
      "perMachine": false,
      "allowToChangeInstallationDirectory": true
    },
    "publish": {
      "provider": "github",
      "owner": "orchestra-dev",
      "repo": "orchestra"
    }
  },
  "dependencies": {
    "electron-store": "^10.0.1",
    "execa": "^9.5.2",
    "lucide-react": "^0.511.0",
    "pidusage": "^3.0.2",
    "ps-list": "^8.1.1",
    "react": "^19.1.0",
    "react-dom": "^19.1.0",
    "systeminformation": "^5.25.11",
    "yaml": "^2.8.0",
    "zod": "^3.25.28",
    "zustand": "^5.0.4"
  },
  "devDependencies": {
    "@types/node": "^22.15.17",
    "@types/react": "^19.1.4",
    "@types/react-dom": "^19.1.5",
    "@vitejs/plugin-react": "^4.3.4",
    "concurrently": "^9.1.2",
    "electron": "^35.2.1",
    "electron-builder": "^26.0.12",
    "tsx": "^4.20.5",
    "typescript": "^5.8.3",
    "vite": "^6.3.5",
    "vitest": "^4.1.4",
    "wait-on": "^8.0.3"
  }
}
