# =============================================================================
# ORCHESTRA BACKEND - CONFIGURATION TEMPLATE
# =============================================================================
# Copier ce fichier vers .env pour le développement local
# Voir ../CONFIGURATION.md pour les instructions détaillées

# -----------------------------------------------------------------------------
# SERVER
# -----------------------------------------------------------------------------
PORT=4000
FRONTEND_URL=http://localhost:3322

# -----------------------------------------------------------------------------
# SUPABASE (Base de données + Auth)
# -----------------------------------------------------------------------------
SUPABASE_URL=
SUPABASE_SERVICE_KEY=

# -----------------------------------------------------------------------------
# JWT
# -----------------------------------------------------------------------------
JWT_SECRET=

# -----------------------------------------------------------------------------
# GITHUB (OAuth)
# -----------------------------------------------------------------------------
GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=

# -----------------------------------------------------------------------------
# STRIPE (Paiements)
# -----------------------------------------------------------------------------
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
STRIPE_PRICE_PRO=
STRIPE_PRICE_TEAM=

# -----------------------------------------------------------------------------
# AI (Optionnel)
# -----------------------------------------------------------------------------
OPENAI_API_KEY=
ANTHROPIC_API_KEY=
