{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "Ports Configuration",
  "description": "Configuration for services, ports, and profiles",
  "type": "object",
  "properties": {
    "services": {
      "type": "object",
      "additionalProperties": {
        "type": "object",
        "properties": {
          "name": { "type": "string" },
          "path": { "type": "string" },
          "command": { "type": "string" },
          "port": { "type": "number" },
          "env": {
            "type": "object",
            "additionalProperties": { "type": "string" }
          },
          "healthCheck": {
            "type": "object",
            "properties": {
              "type": { "enum": ["http", "tcp", "process"] },
              "url": { "type": "string" },
              "timeout": { "type": "number" }
            },
            "required": ["type"]
          },
          "dependencies": {
            "type": "array",
            "items": { "type": "string" }
          }
        },
        "required": ["name", "path", "command"]
      }
    },
    "profiles": {
      "type": "object",
      "additionalProperties": {
        "type": "object",
        "properties": {
          "name": { "type": "string" },
          "services": {
            "type": "array",
            "items": { "type": "string" }
          }
        },
        "required": ["name", "services"]
      }
    }
  },
  "required": ["services", "profiles"]
}
